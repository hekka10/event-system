DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

JWT_SECRET=replace-with-a-long-random-jwt-secret-at-least-32-characters

DB_NAME=event_system
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5433

FRONTEND_BASE_URL=http://localhost:5173
GOOGLE_OAUTH_CLIENT_ID=
PAYMENT_PROVIDER=MOCK
PAYMENT_WEBHOOK_SECRET=replace-with-a-webhook-secret
STUDENT_DISCOUNT_PERCENT=20

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=no-reply@smartevents.com

CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_USE_SQLITE_FOR_TESTS=True
